    "typescript-sdk",
    "python-sdk",
    "arbitrage",
    "positive-ev",
    "line-movement",
    "sportsbook",
    "rest-api"
  ],
  "homepage": "https://odds-api.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odds-api/odds-api.git"
  },
  "bugs": {
    "url": "https://github.com/odds-api/odds-api/issues"
  },
  "type": "module",
  "workspaces": [
    "sdks/typescript",
    "mcp-server"
